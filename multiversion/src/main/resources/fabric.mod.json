{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "${description}",
  "authors": [
    "CreeperSense"
  ],
  "contact": {
    "sources": "${source}",
    "issues": "${issues}"
  },
  "license": "${license}",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.creepersense.platform.FabricClientEntrypoint"
    ]
  },
  "mixins": [
    "${id}.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": "*",
    "minecraft": "${mcdep}",
    "java": ">=21"
  }
}

